import pytest
import os
import re
from pathlib import Path

class TestReadmeStructure:
    """Tests to verify README.md structure and content integrity."""
    
    @pytest.fixture(scope="class")
    def readme_content(self):
        """Load README.md content."""
        readme_path = Path("README.md")
        if not readme_path.exists():
            pytest.skip("README.md not found")
        return readme_path.read_text(encoding="utf-8")
    
    def test_readme_file_exists(self):
        """Verify README.md exists in repository root."""
        assert Path("README.md").exists(), "README.md file should exist"
    
    def test_readme_has_title(self, readme_content):
        """Verify README has proper title header."""
        assert "# CI/CD Pipeline Project" in readme_content, "README should have main title"
    
    def test_readme_has_badges(self, readme_content):
        """Verify README contains status badges."""
        assert "![Build Status]" in readme_content or "badge.svg" in readme_content, "README should have build status badge"
        assert "![License:" in readme_content or "MIT" in readme_content, "README should have license badge"
    
    def test_readme_has_table_of_contents(self, readme_content):
        """Verify README has table of contents section."""
        toc_patterns = ["## 📋 Table of Contents", "## Table of Contents"]
        assert any(pattern in readme_content for pattern in toc_patterns), "README should have table of contents"
        
        # Check for common TOC links
        assert "[Prerequisites]" in readme_content or "(#prerequisites)" in readme_content.lower()
        assert "[Installation" in readme_content or "(#installation" in readme_content.lower()
    
    def test_readme_has_prerequisites_section(self, readme_content):
        """Verify README has prerequisites section."""
        assert "## ✅ Prerequisites" in readme_content or "## Prerequisites" in readme_content
        assert "Node.js" in readme_content, "Should mention Node.js prerequisite"
        assert "npm" in readme_content or "yarn" in readme_content, "Should mention package manager"
    
    def test_readme_has_installation_section(self, readme_content):
        """Verify README has installation instructions."""
        assert "## 🚀 Installation" in readme_content or "## Installation" in readme_content
        assert "git clone" in readme_content, "Should have git clone instructions"
        assert "npm install" in readme_content, "Should have npm install instructions"
    
    def test_readme_has_usage_section(self, readme_content):
        """Verify README has usage instructions."""
        assert "## 💻 Usage" in readme_content or "## Usage" in readme_content
        assert "npm start" in readme_content or "npm run dev" in readme_content
    
    def test_readme_has_cicd_documentation(self, readme_content):
        """Verify README documents CI/CD pipeline."""
        assert "## 🔄 CI/CD Pipeline" in readme_content or "## CI/CD" in readme_content
        assert "GitHub Actions" in readme_content, "Should mention GitHub Actions"
        assert ".github/workflows" in readme_content, "Should reference workflow files"
    
    def test_readme_has_deployment_section(self, readme_content):
        """Verify README has deployment information."""
        assert "## 🌐 Deployment" in readme_content or "## Deployment" in readme_content
        assert "AWS" in readme_content, "Should mention AWS"
        # Check for IP addresses or URLs (should be formatted as links)
        url_pattern = r'\[.*?\]\(http.*?\)'
        assert re.search(url_pattern, readme_content), "Should have clickable URLs"
    
    def test_readme_has_api_documentation(self, readme_content):
        """Verify README has API documentation."""
        assert "## 📚 API Documentation" in readme_content or "## API" in readme_content
        assert "/health" in readme_content, "Should document health endpoint"
        assert "GET" in readme_content or "POST" in readme_content, "Should have HTTP methods documented"
    
    def test_readme_has_architecture_section(self, readme_content):
        """Verify README has architecture diagram/section."""
        assert "## 🏗️ Architecture" in readme_content or "## Architecture" in readme_content
        # Check for ASCII diagram or architecture description
        assert "GitHub" in readme_content and "AWS" in readme_content, "Should mention architecture components"
    
    def test_readme_has_contributing_section(self, readme_content):
        """Verify README has contributing guidelines."""
        assert "## 🤝 Contributing" in readme_content or "## Contributing" in readme_content
        assert "branch" in readme_content.lower(), "Should mention branch naming"
        assert "commit" in readme_content.lower(), "Should mention commit standards"
    
    def test_readme_has_environment_variables_section(self, readme_content):
        """Verify README documents environment variables."""
        assert "## 🔐 Environment Variables" in readme_content or "## Environment Variables" in readme_content
        assert "PORT" in readme_content, "Should document PORT variable"
        assert "NODE_ENV" in readme_content, "Should document NODE_ENV variable"
        assert ".env" in readme_content, "Should mention .env files"
    
    def test_readme_has_troubleshooting_section(self, readme_content):
        """Verify README has troubleshooting section."""
